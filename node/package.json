{
  "name": "btg-mfo-api-client",
  "version": "1.0.1",
  "description": "TypeScript client for the BTG Pactual MFO APIs (Auth, Position, and Operation).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepublishOnly": "pnpm run lint && pnpm run build",
    "release": "tsx scripts/publish.ts"
  },
  "keywords": [
    "btg",
    "btg-pactual",
    "mfo",
    "api",
    "client",
    "finance",
    "brazil",
    "typescript"
  ],
  "author": "Bruno Lobo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lobobruno/btg-mfo-api-client.git"
  },
  "bugs": {
    "url": "https://github.com/lobobruno/btg-mfo-api-client/issues"
  },
  "homepage": "https://github.com/lobobruno/btg-mfo-api-client#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
